# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres URL for migrations (required on Netlify production builds)
# Supabase Dashboard → Project Settings → Database → Connection string (URI, pooler/session mode)
SUPABASE_POOLER=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# App URL (required)
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app

# Email via Resend (optional — notifications no-op without this)
RESEND_API_KEY=re_your_key
RESEND_FROM=CiaoBob <noreply@yourdomain.com>

# Slack reminders (optional — DM notifications for check-in deadlines)
# JSON object mapping email domain to Slack bot token
# e.g. {"yourdomain.com":"xoxb-your-token"}
SLACK_WORKSPACE_TOKENS={}

# Secret to authenticate Netlify scheduled function HTTP calls (optional but recommended)
REMINDER_SECRET=your-random-secret

# Override today's date for reminder testing (format: YYYY-MM-DD)
REMINDER_DATE_OVERRIDE=
